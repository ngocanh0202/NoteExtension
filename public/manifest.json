{
    "name": "Note",
    "version": "1.0.0",
    "description": "Note something",
    "manifest_version": 3,
    "author": "NA",
    "action": {
        "default_icon": "images/default.svg",
        "default_popup": "index.html"
    },
    "permissions" : [
        "contextMenus",
        "activeTab",
        "storage"
    ],
    "background": {
        "service_worker": "contextMenusNote.js"
    },
    "icons": {
        "16": "images/default.svg",
        "48": "images/default.svg",
        "128": "images/default.svg"
    },
    "web_accessible_resources": [
        {
            "resources": ["offscreen.html", "auth.html", "auth.js"],
            "matches": ["<all_urls>"]
        }
    ]
}